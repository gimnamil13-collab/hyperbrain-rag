# HYPERBRAIN RAG — Backend environment variables
# Copy to project root as .env for local development

# Required
OPENAI_API_KEY=sk-your-key-here

# CORS — comma-separated frontend origins (local default)
CORS_ORIGINS=http://localhost:3000

# ChromaDB path (auto-detected on Windows via %LOCALAPPDATA%\HyperbrainRAG\chroma_db)
# CHROMA_DIR=C:\path\to\chroma_db

# Rate limit per IP per minute (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# Optional API key — require X-API-Key header when set (empty = disabled, recommended for local)
# API_SECRET_KEY=your-secret-key

# Max upload size per file in bytes (default 10MB)
# MAX_UPLOAD_BYTES=10485760

# RAG tuning (optional — defaults: RETRIEVAL_K=6, MAX_HISTORY_MESSAGES=12, CHUNK_OVERLAP=120)
# RETRIEVAL_K=6
# MAX_HISTORY_MESSAGES=12
# CHUNK_OVERLAP=120

# Optional model overrides
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
