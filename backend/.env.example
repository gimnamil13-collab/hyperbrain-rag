# HYPERBRAIN RAG — Backend environment variables
# Copy to Railway/Render dashboard or root .env for local dev

# Required
OPENAI_API_KEY=sk-your-key-here

# CORS — comma-separated frontend origins
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000

# Allow Vercel preview deployments (*.vercel.app) — recommended for production backend
ALLOW_VERCEL_PREVIEWS=false

# ChromaDB path (auto-detected on Windows; set explicitly on Linux/cloud)
# CHROMA_DIR=/tmp/hyperbrain_rag/chroma_db

# Rate limit per IP per minute (0 = disabled)
RATE_LIMIT_PER_MINUTE=60

# Optional API key — require X-API-Key header when set (empty = disabled)
# API_SECRET_KEY=your-secret-key

# Max upload size per file in bytes (default 10MB)
# MAX_UPLOAD_BYTES=10485760

# RAG tuning (optional — defaults: RETRIEVAL_K=6, MAX_HISTORY_MESSAGES=12, CHUNK_OVERLAP=120)
# RETRIEVAL_K=6
# MAX_HISTORY_MESSAGES=12
# CHUNK_OVERLAP=120

# Optional model overrides
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
